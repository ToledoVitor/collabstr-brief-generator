# ── LLM provider (provider-agnostic; everything driven by env) ────────────────
# Which backend to call: "openai", "anthropic", or "fake" (offline canned output).
LLM_PROVIDER=anthropic
# Model id is controlled entirely here — the code never hardcodes a model.
LLM_MODEL=claude-haiku-4-5
# Sampling. Temperature is additionally CLAMPED to <= 0.5 server-side (guardrail).
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=900

# Set the key matching LLM_PROVIDER. The SDKs read these from the environment.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Django ────────────────────────────────────────────────────────────────────
# DEBUG defaults to false in code; set true for local dev (enables the dev SECRET_KEY
# fallback + the localhost ALLOWED_HOSTS default). NEVER true in production.
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-insecure-change-me
# Comma-separated host allowlist. REQUIRED when DJANGO_DEBUG=false.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Proxy / rate limiting ─────────────────────────────────────────────────────
# Trusted reverse-proxy hops in front of the app, used to read the real client IP
# from X-Forwarded-For without trusting spoofed entries. 0 = no proxy (local dev,
# trust REMOTE_ADDR); Render / most PaaS = 1.
TRUSTED_PROXY_COUNT=0
# Per-client-IP request cap, fixed 60s window.
RATE_LIMIT_PER_MIN=12
